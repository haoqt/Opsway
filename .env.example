# =============================================================
# OPSWAY — Environment Variables
# Copy to .env and fill in values
# =============================================================

# ----- App -----
APP_ENV=development
SECRET_KEY=change-me-super-secret-key-32chars
FRONTEND_URL=http://localhost:3000

# ----- Database (Opsway metadata) -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=opsway
POSTGRES_USER=opsway
POSTGRES_PASSWORD=opsway_secret
DATABASE_URL=postgresql+asyncpg://opsway:opsway_secret@postgres:5432/opsway

# ----- Redis (Celery broker) -----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ----- GitHub OAuth -----
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ----- GitLab OAuth (Phase 2) -----
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=

# ----- MinIO (Backups) -----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=opsway_minio
MINIO_SECRET_KEY=opsway_minio_secret
MINIO_BUCKET_BACKUPS=opsway-backups
MINIO_SECURE=false

# ----- Docker -----
DOCKER_SOCKET=/var/run/docker.sock
OPSWAY_NETWORK_PREFIX=opsway_proj

# ----- Traefik -----
TRAEFIK_DOMAIN=localhost
# For production: TRAEFIK_DOMAIN=opsway.io
# ACME_EMAIL=admin@opsway.io

# ----- MailHog -----
MAILHOG_HOST=mailhog
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025

# ----- Odoo Images -----
ODOO_IMAGE_V16=odoo:16.0
ODOO_IMAGE_V17=odoo:17.0
ODOO_IMAGE_V18=odoo:18.0

# ----- Build Runner -----
BUILD_WORKSPACE=/opt/opsway/builds
BUILD_TIMEOUT=600
MAX_CONCURRENT_BUILDS=5

# ----- JWT -----
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
